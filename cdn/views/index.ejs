        .jw-state-playing.jw-floating-dismissible.jw-keep-thumbnail.jw-flag-cast-available.jw-floating-dismissible .jwplayer.jw-flag-media-audio.jw-state-playing #secondary-sub-display,
        .jwplayer.jw-state-playing:not(.jw-flag-user-inactive):not(.jw-flag-controls-hidden) #secondary-sub-display,
        .jwplayer:not(.jw-flag-controls-hidden):not(.jw-state-playing) #secondary-sub-display {
            bottom: 40px !important;
        }

        .jwplayer.jw-state-idle .jw-preview,
        .jwplayer.jw-state-complete .jw-preview {
            width: calc(100% + 5rem);
            background-size: calc(100% + 6rem);
            -webkit-transition: opacity 0.35s, -webkit-transform 0.35s;
            transition: opacity 0.35s, -webkit-transform 0.35s;
            transition: opacity 0.35s, transform 0.35s;
            transition: opacity 0.35s, transform 0.35s, -webkit-transform 0.35s;
            -webkit-transform: translate3d(-4rem, 0, 0);
            transform: translate3d(-4rem, 0, 0);
            background-repeat: no-repeat;
            background-size: cover;
        }

        .jwplayer.jw-state-idle:hover .jw-preview,
        .jwplayer.jw-state-complete:hover .jw-preview {
            -webkit-transform: translate3d(0, 0, 0);
            transform: translate3d(0, 0, 0);
        }


        /* 3. ĐIỀU CHỈNH RIÊNG CHO PC / TABLET (Màn hình > 768px) */
        @media (min-width: 768px) {

            .jw-state-playing.jw-floating-dismissible.jw-keep-thumbnail.jw-flag-cast-available.jw-floating-dismissible .jwplayer.jw-flag-media-audio.jw-state-playing #secondary-sub-display,
            .jwplayer.jw-state-playing:not(.jw-flag-user-inactive):not(.jw-flag-controls-hidden) #secondary-sub-display,
            .jwplayer:not(.jw-flag-controls-hidden):not(.jw-state-playing) #secondary-sub-display {
                bottom: 60px !important;
            }

        }

        /* 4. ĐIỀU CHỈNH CHO MÀN HÌNH RẤT LỚN (Option thêm) */
        @media (min-width: 1280px) {

            .jw-state-playing.jw-floating-dismissible.jw-keep-thumbnail.jw-flag-cast-available.jw-floating-dismissible .jwplayer.jw-flag-media-audio.jw-state-playing #secondary-sub-display,
            .jwplayer.jw-state-playing:not(.jw-flag-user-inactive):not(.jw-flag-controls-hidden) #secondary-sub-display,
            .jwplayer:not(.jw-flag-controls-hidden):not(.jw-state-playing) #secondary-sub-display {
                bottom: 80px !important;
            }

        }


        /* ================================================================== */
        /* 6. RESPONSIVE (MOBILE & TABLET) - FIX CAO THẤP                    */
        /* ================================================================== */

        .jwplayer.jw-stretch-uniform .jw-media video {
            object-fit: cover !important;
        }

        @media (max-width: 1268px) {
            .jw-icon.jw-icon-inline.jw-text.jw-reset.jw-text-elapsed {
                left: 30px !important;
            }

            .jw-icon.jw-icon-inline.jw-text.jw-reset.jw-text-duration {
                right: 30px !important;
            }

            .jw-controlbar.jw-reset {
                padding: 0 !important;
            }
        }

        @media (max-width: 768px) {
            .jw-controlbar {
                flex-direction: column-reverse !important;
            }

            .jw-icon.jw-icon-inline.jw-text.jw-reset.jw-text-elapsed {
                left: 25px !important;
            }

            .jw-icon.jw-icon-inline.jw-text.jw-reset.jw-text-duration {
                right: 25px !important;
            }

            .jw-slider-horizontal.jw-chapter-slider-time .jw-slider-container .jw-timesegment-resetter {
                height: 7px !important;
            }

            .custom-controls {
                position: relative;
                bottom: -8px;
            }

            .jw-reset.jw-button-container {
                display: flex !important;
                align-items: center !important;
                justify-content: flex-end !important;
                width: 100% !important;
            }

            .jwplayer.jw-stretch-uniform .jw-media video {
                object-fit: contain !important;
            }

        }
