<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <title>Netflix Skin - Tailwind CSS JWPlayer</title>
    <meta name="robots" content="noindex" />


    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        .jwplayer .jw-display-icon-container .jw-icon-display {
            justify-content: center;
            align-items: center;
            transition: all 0.3s ease;
        }


        .jw-controlbar .jw-tooltip,
        .jw-display-controls .jw-tooltip,
        .jw-settings-menu .jw-tooltip,
        .jw-time-tip,
        .jw-controlbar .jw-tooltip .jw-text,
        .jw-display-controls .jw-tooltip .jw-text,
        .jw-settings-menu .jw-tooltip .jw-text,
        .jw-time-tip .jw-text {
            border-radius: 10px !important;
            font-weight: 500 !important;

        }

        .jw-controlbar.jw-reset {
            background: #14161e;
            background: linear-gradient(0deg, rgba(20, 22, 30, .8), rgba(20, 22, 30, 0));
        }

        #player.jwplayer .jw-display-icon-container .jw-icon-display .jw-svg-icon {
            fill: #ffffffb0 !important;
            width: 80px !important;
            height: 80px !important;
        }

        #player.jwplayer .jw-display-icon-container .jw-icon-display.jw-button-color:hover .jw-svg-icon {
            fill: #ffe195 !important;
        }

        .jwplayer .jw-display-icon-container .jw-icon-display .jw-svg-icon {
            fill: #fff !important;
            width: 30px !important;
            height: 30px !important;
        }

        .jwplayer.jw-state-buffering .jw-display-icon-container .jw-icon-display {
            background-color: transparent !important;
            border: none !important;
        }

        .jw-flag-touch .jw-slider-horizontal.jw-chapter-slider-time .jw-slider-container::before {
            height: auto !important;
        }

        /* ================================================================== */
        /* 2. CONTROL BAR & SLIDER UI (Giữ nguyên)                            */
        /* ================================================================== */
        .jw-controlbar.jw-reset {
            padding: 0 12px 16px !important;
            max-height: -webkit-fill-available !important;
        }

        @keyframes gradientMove {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        #player.jwplayer .jw-display-icon-container .jw-icon-display .jw-svg-icon {
            fill: #ffe195 !important;
            width: 80px !important;
            height: 80px !important;
        }

        .jw-slider-horizontal.jw-chapter-slider-time .jw-slider-container .jw-timesegment-progress {
            background-color: #ffe195 !important;
            background-size: 300% 300% !important;
            animation: gradientMove 12s ease infinite;

        }

        .jw-slider-horizontal.jw-chapter-slider-time .jw-slider-container .jw-timesegment-resetter {
            height: 10px !important;
        }

        .jw-state-idle.jw-flag-cardboard-available .jw-controlbar .jw-icon:not(.jw-icon-cardboard):not(.jw-icon-cast):not(.jw-icon-airplay),
        .jw-state-idle.jw-flag-cardboard-available .jw-controlbar .custom-controls,
        .jw-state-idle.jw-flag-cast-available:not(.jw-flag-audio-player) .jw-controlbar .jw-icon:not(.jw-icon-cardboard):not(.jw-icon-cast):not(.jw-icon-airplay),
        .jw-state-idle.jw-flag-cast-available:not(.jw-flag-audio-player) .jw-controlbar .custom-controls,
        .jw-icon.jw-icon-inline.jw-text.jw-reset.jw-text-duration::before {
            display: none !important;
        }

        /* ================================================================== */
        /* 3. TIME LABELS (Giữ nguyên)                                        */
        /* ================================================================== */
        .jw-icon.jw-icon-inline.jw-text.jw-reset.jw-text-elapsed,
        .jw-icon.jw-icon-inline.jw-text.jw-reset.jw-text-duration {
            position: absolute;
            top: -46px;
            font-size: 13px;
            padding: 0;
        }

        .jw-icon.jw-icon-inline.jw-text.jw-reset.jw-text-elapsed {
            left: 5px !important;
        }

        .jw-icon.jw-icon-inline.jw-text.jw-reset.jw-text-duration {
            right: 5px !important;
        }

        /* ================================================================== */
        /* 4. THUMBNAIL PREVIEW (Giữ nguyên)                                  */
        /* ================================================================== */
        .jwplayer .jw-controlbar .jw-preview {
            width: auto !important;
            background-size: cover !important;
            transform: none !important;
            background-repeat: no-repeat !important;
            opacity: 1 !important;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-sizing: content-box !important;
        }

        .jw-tooltip-time .jw-preview {
            border-radius: 4px;
            margin-bottom: 10px;
        }

        .jwplayer .jw-tooltip-time {
            transform: translateX(-50%);
            margin-left: 0 !important;
        }

        /* 2. Trạng thái khi thanh control HIỆN (User Active hoặc Paused) */
        /* Class .jw-flag-user-active được Player tự thêm khi di chuột/chạm màn hình */
        /* Class .jw-state-paused được Player thêm khi đang Pause */


