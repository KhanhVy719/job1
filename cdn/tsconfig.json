{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext", // QUAN TRỌNG: Sử dụng Module resolution mới của Node
    "moduleResolution": "NodeNext", // QUAN TRỌNG
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "resolveJsonModule": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["**/*.ts"]
}