# Copy các biến này vào secret manager hoặc file .env trên VPS.
# Không commit file .env thật.

MONGO_DATABASE=rophim
MONGO_APP_USER=rophim_app
MONGO_APP_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
MONGO_ADMIN_USER=<CHANGE_ME_ADMIN_USER>
MONGO_ADMIN_PASSWORD=<CHANGE_ME_ADMIN_PASSWORD>

# App cùng VPS database:
MONGODB_URI=mongodb://rophim_app:<CHANGE_ME_STRONG_PASSWORD>@127.0.0.1:27017/rophim?authSource=admin

# App VPS khác qua private IP/VPN sau này:
# MONGODB_URI=mongodb://rophim_app:<CHANGE_ME_STRONG_PASSWORD>@10.8.0.2:27017/rophim?authSource=admin

MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=0

MONGO_BACKUP_DIR=/var/backups/rophim-mongodb
MONGO_BACKUP_RETENTION_DAYS=7
