# Caddy reverse proxy cho RoPhim
# Tự động cấp & gia hạn TLS (Let's Encrypt) cho từng domain.
# Caddy tự xử lý WebSocket upgrade (Socket.io ở cdn/server) — không cần cấu hình thêm.
#
# DNS yêu cầu: 4 bản ghi A (hoặc AAAA) trỏ về IP công khai của VPS:
#   phim.tranhungdaocfs.site  -> VPS
#   api1.tranhungdaocfs.site  -> VPS
#   cdn.tranhungdaocfs.site   -> VPS
#   core.tranhungdaocfs.site  -> VPS
#   admin.tranhungdaocfs.site -> VPS

# Email dùng cho Let's Encrypt (đổi nếu cần)
{
	email admin@tranhungdaocfs.site
}

# Site phim chính (client, Next.js)
phim.tranhungdaocfs.site {
	encode zstd gzip
	reverse_proxy client:3000
}

# Web API (webapi)
api1.tranhungdaocfs.site {
	encode zstd gzip
	reverse_proxy webapi:8001
}

# CDN / HLS streaming (cdn) — không nén video (HLS đã nén), tăng timeout cho stream
cdn.tranhungdaocfs.site {
	reverse_proxy cdn:8001 {
		flush_interval -1
	}
}

# Core service (server)
core.tranhungdaocfs.site {
	encode zstd gzip
	reverse_proxy server:8001
}

# Admin dashboard (admin, Next.js)
admin.tranhungdaocfs.site {
	encode zstd gzip
	reverse_proxy admin:3001
}
