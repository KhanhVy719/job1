# RoPhim public reverse proxy.
# DNS must point these hosts to the VPS:
# peakfilm.net, flim.peakfilm.net, api.peakfilm.net, cdn.peakfilm.net,
# core.peakfilm.net, adminpeakflim.peakfilm.net

{
	email admin@peakfilm.net
}

peakfilm.net {
	encode zstd gzip

	@watch_page path_regexp watch_page ^/phim/[^/]+/[^/]+/[^/]+$
	redir @watch_page https://flim.peakfilm.net{uri} 302

	@next_static path /_next/static/*
	handle @next_static {
		reverse_proxy client:3000 {
			header_down Cache-Control "public, max-age=31536000, immutable"
			header_down -Set-Cookie
		}
	}

	@public_assets path_regexp public_assets ^/(favicon\.ico|site\.webmanifest|robots\.txt|sitemap(?:-\d+)?\.xml|images/.*|events/.*|gtag\.js)$
	handle @public_assets {
		reverse_proxy client:3000 {
			header_down Cache-Control "public, max-age=86400, stale-while-revalidate=604800"
			header_down -Set-Cookie
		}
	}

	handle {
		reverse_proxy client:3000
	}
}

flim.peakfilm.net {
	encode zstd gzip

	@next_static path /_next/static/*
	handle @next_static {
		reverse_proxy client:3000 {
			header_down Cache-Control "public, max-age=31536000, immutable"
			header_down -Set-Cookie
		}
	}

	@public_assets path_regexp public_assets ^/(favicon\.ico|site\.webmanifest|robots\.txt|sitemap(?:-\d+)?\.xml|images/.*|events/.*|gtag\.js)$
	handle @public_assets {
		reverse_proxy client:3000 {
			header_down Cache-Control "public, max-age=86400, stale-while-revalidate=604800"
			header_down -Set-Cookie
		}
	}

	handle {
		reverse_proxy client:3000
	}
}

api.peakfilm.net {
	encode zstd gzip
	reverse_proxy webapi:8001 {
		header_down Cache-Control "no-store"
	}
}

cdn.peakfilm.net {
	@player_static path /video.html /x.html /index.html /sw-tiktok-hls.js /assets/*
	handle @player_static {
		reverse_proxy cdn:8001 {
			header_down Cache-Control "public, max-age=86400, stale-while-revalidate=604800"
			header_down -Set-Cookie
		}
	}

	handle {
		reverse_proxy cdn:8001 {
			flush_interval -1
		}
	}
}

core.peakfilm.net {
	encode zstd gzip

	@core_api path /api/*
	handle @core_api {
		reverse_proxy server:8001 {
			header_down Cache-Control "no-store"
		}
	}

	@player_static path /video.html /index.html /player-icons.css /assets/*
	handle @player_static {
		reverse_proxy server:8001 {
			header_down Cache-Control "public, max-age=86400, stale-while-revalidate=604800"
			header_down -Set-Cookie
		}
	}

	@hls_segments path /stream/*/seg/*
	handle @hls_segments {
		reverse_proxy server:8001 {
			header_down Cache-Control "public, max-age=31536000, immutable"
		}
	}

	handle {
		reverse_proxy server:8001
	}
}

adminpeakflim.peakfilm.net {
	encode zstd gzip

	@next_static path /_next/static/*
	handle @next_static {
		reverse_proxy admin:3001 {
			header_down Cache-Control "public, max-age=31536000, immutable"
			header_down -Set-Cookie
		}
	}

	@public_assets path_regexp public_assets ^/(favicon\.ico|site\.webmanifest|robots\.txt|sitemap(?:-\d+)?\.xml|images/.*|assets/.*|app\.js|app\.html|style\.min\.css|c\.css)$
	handle @public_assets {
		reverse_proxy admin:3001 {
			header_down Cache-Control "public, max-age=86400, stale-while-revalidate=604800"
			header_down -Set-Cookie
		}
	}

	handle {
		reverse_proxy admin:3001
	}
}
