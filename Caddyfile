# Caddy reverse proxy cho RoPhim
# Tự động cấp & gia hạn TLS (Let's Encrypt) cho từng domain.
# Caddy tự xử lý WebSocket upgrade (Socket.io ở cdn/server) — không cần cấu hình thêm.
#
# DNS yêu cầu: 6 bản ghi A (hoặc AAAA) trỏ về IP công khai của VPS:
#   peakfilm.net                   -> VPS
#   flim.peakfilm.net              -> VPS
#   api.peakfilm.net               -> VPS
#   cdn.peakfilm.net               -> VPS
#   core.peakfilm.net              -> VPS
#   adminpeakflim.peakfilm.net     -> VPS

# Email dùng cho Let's Encrypt (đổi nếu cần)
{
	email admin@peakfilm.net
}

# Site phim chính (client, Next.js)
peakfilm.net {
	encode zstd gzip

	@watch_page path_regexp watch_page ^/phim/[^/]+/[^/]+/[^/]+$
	redir @watch_page https://flim.peakfilm.net{uri} 302

	reverse_proxy client:3000
}

# Domain xem phim (client, Next.js)
flim.peakfilm.net {
	encode zstd gzip
	reverse_proxy client:3000
}

# Web API (webapi)
api.peakfilm.net {
	encode zstd gzip
	reverse_proxy webapi:8001
}

# CDN / HLS streaming (cdn) — không nén video (HLS đã nén), tăng timeout cho stream
cdn.peakfilm.net {
	reverse_proxy cdn:8001 {
		flush_interval -1
	}
}

# Core service (server)
core.peakfilm.net {
	encode zstd gzip
	reverse_proxy server:8001
}

# Admin dashboard (admin, Next.js)
adminpeakflim.peakfilm.net {
	encode zstd gzip
	reverse_proxy admin:3001
}
